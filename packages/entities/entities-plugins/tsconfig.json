{
  "extends": "../../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "outDir": "dist",
    "declarationDir": "dist/types",
    "paths": {
      "@kong-ui-public/entities-redis-configurations": ["../entities-redis-configurations/src/index.ts"],
      "@kong-ui-public/entities-routes": ["../entities-routes/src/index.ts"],
