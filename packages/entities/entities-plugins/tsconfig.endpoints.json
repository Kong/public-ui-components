{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "es5",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "./dist/endpoints",
    "declaration": true,
    "declarationDir": "./dist/endpoints",
    "sourceMap": false,
    "lib": [
      "esnext",
      "dom",
      "dom.iterable"
    ],
    "types": [
      "node",
    ]
  },
  "include": [
    "src/plugins-endpoints.ts"
  ],
  "files": [
    "src/plugins-endpoints.ts"
  ]
}
